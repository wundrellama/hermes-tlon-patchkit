+class FakeActionSession:
+    def __init__(self):
+        self.put_calls = []
+
+    def put(self, url, *, json, headers, timeout):
+        self.put_calls.append(
+            {
+                "url": url,
+                "json": json,
+                "headers": headers,
+                "timeout": timeout,
+            }
+        )
+        return FakeActionResponse()
+
+    async def close(self):
+        pass
