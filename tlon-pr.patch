+    prompt: 'Brave Search API key'
+    password: true
+  - name: BRAVE_API_KEY
+    description:
+      'Older OpenClaw-style Brave API key alias accepted by the dev flow and
+      image_search tool'
+    prompt: 'Brave API key'
+    password: true
