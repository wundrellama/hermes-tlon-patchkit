+# Copy this file to .env before running `pnpm dev`.
+
+# Tlon node credentials.
+TLON_NODE_URL=https://your-node.tlon.network
+TLON_NODE_ID=~your-node
+TLON_ACCESS_CODE=your-access-code
+
+# Full channel nests to monitor. Group messages dispatch when they mention the
+# bot node id, bare node id, profile nickname, or one of TLON_BOT_MENTIONS.
+TLON_CHANNELS=chat/~host/channel
+# Explicit owner for home-channel defaults and gateway-status ownership.
+TLON_OWNER_SHIP=~your-human-ship
+# Optional override for cron/cross-platform delivery. When unset, Hermes uses
+# TLON_OWNER_SHIP as the owner DM.
+TLON_HOME_CHANNEL=
+TLON_BOT_MENTIONS=hermes
+
+# Optional no-mention attention modes. These only activate when TLON_OWNER_SHIP,
+# TLON_ALLOWED_USERS, or TLON_ALLOW_ALL_USERS is set.
+TLON_FREE_RESPONSE_CHANNELS=
+TLON_REQUIRE_MENTION=true
+
+# Owner-listen: the owner is heard without a mention in channels hosted by the
+# bot or owner (default on). The owner can opt any channel in/out at runtime
+# with the /owner-listen chat command; that state persists in the ship's
+# %settings store and overrides these env seeds on boot.
+TLON_OWNER_LISTEN=true
+# Default scope: "owned" (owner/bot-hosted channels) or "all" monitored channels.
+TLON_OWNER_LISTEN_DEFAULT=owned
+TLON_OWNER_LISTEN_DISABLED_CHANNELS=
+TLON_OWNER_LISTEN_ENABLED_CHANNELS=
+
+# Recent channel/thread messages prepended as context when the bot wakes in a
+# group channel. Set 0 to disable.
+TLON_CONTEXT_MESSAGES=20
+
+# Group replies post top-level in the channel; thread conversations are always
+# continued in-thread. Set true to instead start a thread on every trigger.
+TLON_REPLY_IN_THREAD=false
+
+# Optional group-channel bot loop protection. Add known bot ships to enable it.
+TLON_KNOWN_BOT_USERS=
+TLON_MAX_CONSECUTIVE_BOT_RESPONSES=2
+
+# Access control is deny-by-default. TLON_OWNER_SHIP is automatically
+# authorized; use TLON_ALLOWED_USERS for additional pre-authorized ships.
+# Unknown ships queue for owner approval (/pending, /allow, /reject, /ban)
+# when an owner is set. Flip allow-all only for temporary local smoke tests.
+TLON_ALLOWED_USERS=
+TLON_DM_ALLOWLIST=
+TLON_ALLOW_ALL_USERS=false
+# Ships whose group invites auto-accept; others queue for owner approval.
+TLON_GROUP_INVITE_ALLOWLIST=
+
+# Keeps the desk %gateway-status agent from sending offline auto-replies.
+# Defaults to TLON_OWNER_SHIP. Set only if gateway-status should use another owner.
+TLON_GATEWAY_STATUS=true
+TLON_GATEWAY_STATUS_OWNER=
+
+# Reconnect the Eyre SSE channel after this many seconds without bytes.
+# Lower this while testing laptop sleep/wake if needed.
+TLON_SSE_READ_TIMEOUT_SECONDS=60
+
+# Image uploads detect Tlon hosting from the node URL by default, which fails
+# for connections that reach their node over localhost/proxy. Set
+# TLON_HOSTING=true to force the hosted (memex) upload path on such deployments.
+# TLON_HOSTING=true
+
+# Hermes model config for the disposable container profile.
+# Use any provider/model your Hermes install supports.
+HERMES_MODEL_PROVIDER=openrouter
+HERMES_MODEL=your/provider-model
+OPENROUTER_API_KEY=
+
+# Optional: Brave Search for Hermes' web_search tool and the Tlon plugin's
+# image_search tool. The dev container also accepts the older OpenClaw-style
+# BRAVE_API_KEY alias.
+BRAVE_SEARCH_API_KEY=
+# BRAVE_API_KEY=
+
+# Optional: page extraction backend for Hermes' web_extract tool. Brave is
+# search-only, so set one of these if you want OpenClaw web_fetch-like reads.
+# FIRECRAWL_API_KEY=
+# PARALLEL_API_KEY=
+# TAVILY_API_KEY=
+# EXA_API_KEY=
+# Or pin explicitly:
+# HERMES_WEB_SEARCH_BACKEND=brave-free
+# HERMES_WEB_EXTRACT_BACKEND=firecrawl
+
+# Optional: build Hermes from a fork/branch/tag/commit at image build time.
+HERMES_AGENT_REPO=https://github.com/NousResearch/hermes-agent.git
+HERMES_AGENT_REF=main
+
+# Optional: opt-in PostHog telemetry. Strictly content-free (no message text,
+# no CLI arguments); every event is tagged harness: "hermes". See README.
+# Debugging: the resolved state is logged at startup, and the owner can DM
+# /tlon-telemetry (status) or /tlon-telemetry test (live PostHog round trip).
+TLON_TELEMETRY=false
+TLON_TELEMETRY_API_KEY=
+# TLON_TELEMETRY_HOST=
+# Per-event capture logs plus PostHog SDK internals.
+# TLON_TELEMETRY_DEBUG=true
+
+# Optional: increase plugin/gateway logs.
+HERMES_PLUGINS_DEBUG=0
+HERMES_GATEWAY_ARGS=--replace
