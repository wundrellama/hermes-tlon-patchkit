+def channel_event(
+    text,
+    *,
+    author="~mug",
+    nest="chat/~pen/general",
+    post_id="170.141",
+    parent_id=None,
+):
+    set_payload = {
+        "essay": {
+            "author": author,
+            "sent": 1000,
+            "content": [{"inline": [text]}],
+        }
+    }
+    if parent_id:
+        set_payload["seal"] = {"parent-id": parent_id}
+    return {
+        "nest": nest,
+        "response": {
+            "post": {
+                "id": post_id,
+                "r-post": {
+                    "set": set_payload,
+                },
+            }
+        },
+    }
