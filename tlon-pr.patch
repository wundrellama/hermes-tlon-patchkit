+    # ── context enrichment ───────────────────────────────────────────────
+
+    def test_mention_dispatch_includes_channel_context(self):
+        adapter = self.make_adapter({"allowed_users": ["~ten"]})
+        adapter._sse = FakeSSE(
+            payloads={
+                "/channels/v4/chat/~pen/general/posts/newest/20/outline": {
+                    "posts": {
