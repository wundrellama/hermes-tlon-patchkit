+    prompt: 'Group context messages'
+    password: false
+  - name: TLON_TELEMETRY
+    description:
+      'Enable opt-in PostHog telemetry (true/false, default false); requires
+      TLON_TELEMETRY_API_KEY'
+    prompt: 'Enable telemetry?'
+    password: false
+  - name: TLON_TELEMETRY_API_KEY
+    description: 'PostHog project API key for telemetry'
+    prompt: 'PostHog API key'
+    password: true
+  - name: TLON_TELEMETRY_HOST
+    description: 'PostHog host override (defaults to PostHog US cloud)'
+    prompt: 'PostHog host'
+    password: false
+  - name: TLON_TELEMETRY_DEBUG
+    description:
+      'Verbose telemetry logging: per-event capture logs plus PostHog SDK
+      internals (true/false)'
+    prompt: 'Telemetry debug logs?'
+    password: false
+  - name: TLON_CLI
+    description: 'Path/name for the tlon CLI (default: tlon)'
+    prompt: 'tlon CLI'
+    password: false
+  - name: TLON_SSE_READ_TIMEOUT_SECONDS
+    description:
+      'Seconds without SSE bytes before reconnecting the Eyre channel (default:
+      60)'
+    prompt: 'SSE read timeout'
+    password: false
+  - name: TLON_HOSTING
+    description:
+      'Force the hosted (memex) image-upload path (true/false). Needed for
+      connections that reach their node over localhost/proxy, where URL-based
+      hosting detection fails. Leave unset for normal node-URL detection.'
+    prompt: 'Force hosted uploads?'
+    password: false
+  - name: TLON_SKILL_PATH
+    description:
+      'Optional path to @tloncorp/tlon-skill/SKILL.md for explicit plugin-skill
+      registration'
+    prompt: 'Tlon skill path'
+    password: false
+  - name: TLON_GATEWAY_STATUS
+    description:
+      'Enable %gateway-status start/heartbeat/stop pokes (true/false)'
+    prompt: 'Gateway status heartbeat?'
+    password: false
+  - name: TLON_GATEWAY_STATUS_OWNER
+    description:
+      'Optional owner ship override for %gateway-status offline replies;
+      defaults to TLON_OWNER_SHIP'
+    prompt: 'Gateway status owner'
+    password: false
+  - name: BRAVE_SEARCH_API_KEY
+    description:
+      'Brave Search API key; enables Hermes web_search in dev and the
