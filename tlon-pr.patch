+    prompt: 'Owner-listen default (owned|all)'
+    password: false
+  - name: TLON_OWNER_LISTEN_DISABLED_CHANNELS
+    description:
+      'Comma-separated owned channel nests muted for owner-listen (default seed;
+      %settings store overrides)'
+    prompt: 'Owner-listen muted channels'
+    password: false
+  - name: TLON_OWNER_LISTEN_ENABLED_CHANNELS
+    description:
+      'Comma-separated non-owned channel nests opted into owner-listen (default
