+        asyncio.run(run())
+
+        self.assertEqual(
+            reporter.published,
+            [
+                {"conversation_id": "~mug", "thinking": True, "tool_names": []},
+                {"conversation_id": "~mug", "thinking": True, "tool_names": ["tlon"]},
+                {"conversation_id": "~mug", "thinking": True, "tool_names": []},
+            ],
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()
