+                    "dmAllowlist": ["~zod"],
+                    "autoDiscover": True,
+                    "channelRules": '{"chat/~host/general":{"mode":"restricted","allowedShips":["~nec"]}}',
+                    "defaultAuthorizedShips": ["~bus"],
