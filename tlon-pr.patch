+name: tlon-platform
+label: Tlon
+kind: platform
+version: 0.8.0
+description: >
+  Tlon Messenger platform adapter for Hermes Agent. Reads inbound messages from
+  an authenticated Eyre SSE channel and sends replies through the
+  @tloncorp/tlon-skill CLI.
+author: tloncorp
+provides_tools:
+  - tlon
+  - image_search
+provides_hooks:
+  - pre_tool_call
+  - post_tool_call
+  - post_api_request
+requires_env:
+  - name: TLON_NODE_URL
+    description: 'Node URL, for example https://sampel-palnet.tlon.network'
+    prompt: 'Tlon node URL'
+    password: false
+  - name: TLON_NODE_ID
+    description: 'Node ID, for example ~sampel-palnet'
+    prompt: 'Tlon node ID'
+    password: false
+  - name: TLON_ACCESS_CODE
+    description: 'Access code for Eyre authentication'
+    prompt: 'Tlon access code'
+    password: true
+optional_env:
+  - name: TLON_CHANNELS
+    description:
+      'Comma-separated channel nests to monitor, for example chat/~host/general'
+    prompt: 'Tlon channels'
+    password: false
+  - name: TLON_AUTO_DISCOVER
+    description:
+      'Auto-watch chat/heap channels seen on the firehose (true/false)'
+    prompt: 'Auto-discover channels?'
+    password: false
+  - name: TLON_ALLOWED_USERS
+    description:
+      'Comma-separated ships allowed to interact (access is deny-by-default;
+      unknown ships queue for owner approval)'
+    prompt: 'Allowed ships'
+    password: false
+  - name: TLON_ALLOW_ALL_USERS
+    description: 'Allow any ship to interact (dev only)'
+    prompt: 'Allow all ships?'
+    password: false
+  - name: TLON_DM_ALLOWLIST
+    description: 'Comma-separated ships allowed to DM'
+    prompt: 'Allowed DM ships'
+    password: false
+  - name: TLON_GROUP_INVITE_ALLOWLIST
+    description:
+      'Comma-separated ships whose group invites auto-accept (others queue for
+      owner approval); %settings groupInviteAllowlist overrides'
+    prompt: 'Auto-accept group inviters'
+    password: false
+  - name: TLON_OWNER_SHIP
+    description:
+      'Explicit owner ship for home-channel defaults and gateway status'
+    prompt: 'Owner ship'
+    password: false
+  - name: TLON_HOME_CHANNEL
+    description:
+      'Optional home channel/DM for cron and standalone delivery; defaults to
+      TLON_OWNER_SHIP'
+    prompt: 'Home channel'
+    password: false
+  - name: TLON_BOT_MENTIONS
+    description:
+      'Extra comma-separated aliases that trigger group-channel replies'
+    prompt: 'Bot mention aliases'
+    password: false
+  - name: TLON_FREE_RESPONSE_CHANNELS
+    description:
+      'Comma-separated channel nests where allowed users can trigger replies
+      without mentioning the bot'
+    prompt: 'Free-response channels'
+    password: false
+  - name: TLON_REPLY_IN_THREAD
+    description:
+      'Group replies start a thread on the triggering message instead of posting
+      top-level (true/false, default false); existing threads are always
+      continued in-thread'
+    prompt: 'Thread group replies?'
+    password: false
+  - name: TLON_REQUIRE_MENTION
+    description:
+      'Require bot mention/name wake in monitored group channels unless
+      free-response is configured (true/false)'
+    prompt: 'Require group mentions?'
+    password: false
+  - name: TLON_KNOWN_BOT_USERS
+    description:
+      'Comma-separated bot ships subject to group-channel loop protection'
+    prompt: 'Known bot ships'
+    password: false
+  - name: TLON_MAX_CONSECUTIVE_BOT_RESPONSES
+    description:
+      'Maximum consecutive group dispatch attempts from known bot ships before
